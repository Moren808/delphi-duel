# Dependencies
node_modules/

# Environment secrets
.env
.env.local
.env.*.local
.env.local.save
.env.*.save

# AXL identity keys (never commit)
axl/keys/
*.pem

# AXL node configs are generated by `pnpm axl:keys` with absolute paths
# specific to the local clone — gitignored so we don't leak filesystem
# layouts or break checkouts on other machines.
axl/node-config-1.json
axl/node-config-2.json

# AXL cloned repo and built binary
axl/axl-repo/

# SQLite databases
*.db
*.db-shm
*.db-wal

