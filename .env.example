# Copy this to .env.local in each agent directory
# agents/bull/.env.local
# agents/bear/.env.local

ANTHROPIC_API_KEY=sk-ant-...

# AXL HTTP bridge URL for this agent's node
AXL_API_URL=http://127.0.0.1:9002   # bull uses 9002, bear uses 9012

# Peer's AXL public key (64-char hex) — filled in after pnpm axl:keys-show
PEER_PUBLIC_KEY=
