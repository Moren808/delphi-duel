{
  "name": "delphi-duel",
  "version": "0.0.1",
  "private": true,
  "description": "The second opinion engine for Delphi prediction markets — two AI agents debate any market P2P over Gensyn AXL",
  "license": "MIT",
  "keywords": [
    "delphi",
    "prediction-markets",
    "gensyn",
    "axl",
    "agents",
    "ai-agents",
    "p2p"
  ],
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "axl:build": "bash axl/scripts/build.sh",
    "axl:keys": "bash axl/scripts/generate-keys.sh",
    "axl:start": "bash axl/scripts/start-mesh.sh",
    "axl:stop": "bash axl/scripts/stop-mesh.sh",
    "axl:probe": "bash axl/scripts/probe-keys.sh",
    "axl:keys-show": "echo 'Bull:' && curl -s http://127.0.0.1:9002/topology | jq -r .our_public_key && echo 'Bear:' && curl -s http://127.0.0.1:9012/topology | jq -r .our_public_key",
    "dev:bull": "pnpm --filter @delphi-duel/bull dev",
    "dev:bear": "pnpm --filter @delphi-duel/bear dev",
    "dev:judge": "pnpm --filter @delphi-duel/judge dev",
    "dev:web": "pnpm --filter @delphi-duel/web dev",
    "test:mesh": "tsx scripts/test-mesh.ts",
    "run-duel": "tsx scripts/run-duel.ts",
    "fetch-market": "tsx scripts/fetch-market.ts",
    "list-markets": "tsx scripts/list-markets.ts",
    "install:all": "pnpm install"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@delphi-duel/agents-shared": "workspace:*",
    "@delphi-duel/sdk": "workspace:*",
    "@delphi-duel/shared-types": "workspace:*",
    "better-sqlite3": "^11.0.0",
    "dotenv": "^16.0.0",
    "next": "14.2.0",
    "viem": "^2.48.0",
    "zod": "^3.22.0"
  }
}
