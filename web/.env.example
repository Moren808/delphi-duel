# Web UI environment variables.
#
# The Next.js dashboard is view-only and does NOT need API keys for
# normal operation. The /api/start-duel route shells out to the local
# orchestrator (scripts/run-duel.ts), which is what consumes the
# Anthropic and Delphi keys at the *repo root* in .env.local.
#
# So for LOCAL development, just put your keys in <repo-root>/.env.local
# (see .env.example at the repo root). The web dev server does not
# need anything in /web/.env.local.
#
# For VERCEL DEPLOYMENT (view-only demo for judges), set ONLY this:
#
#   NEXT_PUBLIC_DEMO_MODE=1
#
# That flag:
#   • shows a "demo mode" banner at the top of the page
#   • disables the "start duel" button (orchestrator can't spawn in
#     serverless anyway — the route returns 503 in this mode)
#   • leaves "view example duel" enabled so judges can replay a
#     recorded transcript baked into web/fixtures/example-duel.json

NEXT_PUBLIC_DEMO_MODE=1
